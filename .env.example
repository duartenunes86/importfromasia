# ============================================================
# ImportFromAsia — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- Elim.asia API (official 1688 product search) ---
# Account credentials for https://openapi.elim.asia (email + password → JWT)
ELIMAPI_EMAIL=your@email.com
ELIMAPI_PASSWORD=your_password_here

# Base URL for the Elim API (optional — defaults to the value below)
ELIMAPI_BASE_URL=https://openapi.elim.asia

# --- Translation (optional) ---
# MyMemory bumps quota when you provide an email address (free)
# MYMEMORY_EMAIL=your@email.com

# --- App ---
PORT=3001
NODE_ENV=production
